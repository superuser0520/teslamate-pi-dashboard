# Copy this file to .env on your Raspberry Pi and replace the values.
# The setup script can generate safe random values for you.

ENCRYPTION_KEY=replace-with-a-long-random-secret
POSTGRES_PASSWORD=replace-with-a-secure-database-password

DATABASE_USER=teslamate
DATABASE_NAME=teslamate
DATABASE_HOST=database
MQTT_HOST=mosquitto

# Local ports on the Raspberry Pi.
TESLAMATE_PORT=4000
GRAFANA_PORT=3000
DASHBOARD_PORT=8080

# Optional: set this if you want the dashboard API to require
# Authorization: Bearer <token>. Cloudflare Access is still recommended.
DASHBOARD_TOKEN=

# Optional Cloudflare Tunnel token. Start with:
# docker compose --profile tunnel up -d cloudflared
CLOUDFLARED_TOKEN=
